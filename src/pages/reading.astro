---
import BaseLayout from '../layouts/BaseLayout.astro';
import currentBooks from '../content/data/reading-current.json';
import alltimeBooks from '../content/data/reading-alltime.json';
---

<BaseLayout
  title="Reading"
  description="What Rumman Kalam is currently reading and an all-time reading list."
>
  <div class="reading-wrap container">
    <!-- Currently reading -->
    <section class="section">
      <div class="sec-kick"><div class="sec-kick-label">Currently reading</div></div>
      <div class="current-grid">
        {currentBooks.map(book => (
          <div class="book-tile book-tile--current">
            {book.cover
              ? <img src={book.cover} alt={`${book.title} cover`} class="book-cover" loading="lazy" />
              : (
                <div class="book-placeholder">
                  <span class="book-placeholder-title">{book.title}</span>
                </div>
              )
            }
            <div class="book-meta">
              <span class="book-title">{book.title}</span>
              <span class="book-author text-label">{book.author}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- All time -->
    <section class="section">
      <div class="sec-kick"><div class="sec-kick-label">All-time</div></div>
      <div class="alltime-grid">
        {alltimeBooks.map(book => (
          <div class="book-tile">
            {book.cover
              ? <img src={book.cover} alt={`${book.title} cover`} class="book-cover" loading="lazy" />
              : (
                <div class="book-placeholder">
                  <span class="book-placeholder-title">{book.title}</span>
                  <span class="book-placeholder-author">{book.author}</span>
                </div>
              )
            }
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .reading-wrap { padding-bottom: var(--space-16); }
  .section { padding: 64px 0; border-top: 0.5px solid var(--rule); }
  .section:first-child { border-top: none; padding-top: 48px; }

  .current-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    max-width: 560px;
  }

  .alltime-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
  }

  .book-tile {
    position: relative;
  }

  .book-cover {
    width: 100%;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    filter: grayscale(0.3);
  }

  .book-placeholder {
    width: 100%;
    aspect-ratio: 2 / 3;
    background: var(--paper-warm);
    border: 0.5px solid var(--rule);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 12px 8px;
    text-align: center;
    gap: 8px;
    transition: border-color 0.6s ease;
  }

  .book-placeholder-title {
    font-family: var(--font-serif);
    font-size: 11px;
    line-height: 1.4;
    color: var(--ink);
    transition: color 0.6s ease;
  }

  .book-placeholder-author {
    font-size: 9px;
    color: var(--muted);
    letter-spacing: 0.05em;
    transition: color 0.6s ease;
  }

  .book-meta {
    margin-top: 10px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .book-title {
    font-family: var(--font-serif);
    font-size: 15px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.3;
    transition: color 0.6s ease;
  }

  @media (max-width: 900px) {
    .current-grid { grid-template-columns: repeat(2, 1fr); max-width: 100%; }
    .alltime-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
