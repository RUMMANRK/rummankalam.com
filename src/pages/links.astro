---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Grain from '../components/Grain.astro';
import PaperTexture from '../components/PaperTexture.astro';
import linksData from '../content/data/links.json';

const visibleLinks = linksData.links.filter((l) => l.visible !== false);
const { displayName, tagline, location, avatar } = linksData;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <SEO
    title={`${displayName} — Links`}
    description={tagline}
    noindex={true}
  />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script is:inline>
    try {
      if (localStorage.getItem('theme') === 'dark') {
        document.documentElement.setAttribute('data-theme-init', 'dark');
      }
    } catch {}
  </script>
</head>
<body>
  <script is:inline>
    try {
      if (localStorage.getItem('theme') === 'dark') {
        document.body.classList.add('dark');
      }
    } catch {}
  </script>

  <PaperTexture />
  <Grain />

  <main class="links-wrap">
    <header class="links-header">
      <div class="stamp" aria-hidden="true">File · Links</div>
      {avatar && (
        <div class="links-avatar">
          <img src={avatar} alt={displayName} />
          <span class="tape tape-tl" aria-hidden="true"></span>
          <span class="tape tape-br" aria-hidden="true"></span>
        </div>
      )}
      <h1 class="links-name">{displayName}</h1>
      <p class="links-tagline">{tagline}</p>
      {location && <p class="links-loc">{location}</p>}
      <div class="rule" aria-hidden="true"></div>
    </header>

    <nav class="links-list" aria-label="Links">
      {visibleLinks.map((link) => (
        <a
          href={link.href}
          class="link-card"
          target={link.href.startsWith('http') ? '_blank' : undefined}
          rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
        >
          <div class="link-row">
            <span class="link-label">{link.label}</span>
            <span class="link-arrow" aria-hidden="true">→</span>
          </div>
          {link.description && <span class="link-desc">{link.description}</span>}
        </a>
      ))}
    </nav>

    <footer class="links-footer">
      <span>&copy; Rumman Kalam</span>
      <span class="sep">·</span>
      <a href="https://rummankalam.com">rummankalam.com</a>
    </footer>
  </main>
</body>
</html>

<style>
  body {
    min-height: 100vh;
    background: var(--paper);
    transition: background 0.6s ease;
  }

  .links-wrap {
    max-width: 460px;
    margin: 0 auto;
    padding: 56px 24px 48px;
    position: relative;
    z-index: 1;
  }

  .links-header {
    text-align: center;
    margin-bottom: 32px;
    position: relative;
  }

  .stamp {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 20px;
  }

  .links-avatar {
    position: relative;
    width: 120px;
    height: 150px;
    margin: 0 auto 24px;
    transform: rotate(-2deg);
  }

  .links-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .tape {
    position: absolute;
    width: 54px;
    height: 18px;
    background: var(--red-soft);
    border-top: 0.5px solid rgba(214, 40, 40, 0.4);
    border-bottom: 0.5px solid rgba(214, 40, 40, 0.4);
    z-index: 3;
  }

  .tape-tl { top: 6px; left: 6px; transform: rotate(-14deg); }
  .tape-br { bottom: 6px; right: 6px; transform: rotate(9deg); }

  .links-name {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 30px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 10px;
    transition: color 0.6s ease;
  }

  .links-tagline {
    font-family: var(--font-sans);
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin: 0 0 6px;
    transition: color 0.6s ease;
  }

  .links-loc {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0;
    transition: color 0.6s ease;
  }

  .rule {
    width: 40px;
    height: 1px;
    background: var(--red);
    opacity: 0.6;
    margin: 24px auto 0;
  }

  .links-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .link-card {
    display: block;
    padding: 18px 20px;
    border: 0.5px solid var(--rule);
    background: transparent;
    color: var(--ink);
    text-decoration: none;
    transition: border-color 0.25s ease, background 0.25s ease, transform 0.2s ease, color 0.25s ease;
    position: relative;
  }

  .link-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--red);
    transform: scaleY(0);
    transform-origin: top center;
    transition: transform 0.25s cubic-bezier(0.2, 0.9, 0.3, 1);
  }

  .link-card:hover {
    border-color: var(--ink);
    background: rgba(214, 40, 40, 0.03);
    transform: translateY(-1px);
  }

  .link-card:hover::before { transform: scaleY(1); }

  .link-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .link-label {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--ink);
    transition: color 0.2s ease;
  }

  .link-card:hover .link-label { color: var(--red); }

  .link-arrow {
    color: var(--red);
    font-size: 15px;
    transition: transform 0.25s ease;
  }

  .link-card:hover .link-arrow { transform: translateX(4px); }

  .link-desc {
    display: block;
    font-size: 12.5px;
    line-height: 1.5;
    color: var(--muted);
    margin-top: 4px;
    transition: color 0.6s ease;
  }

  .links-footer {
    margin-top: 40px;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
  }

  .links-footer .sep { color: var(--red); }
  .links-footer a { color: inherit; }
  .links-footer a:hover { color: var(--red); }

  :global(body.dark) .links-name,
  :global(body.dark) .link-label { font-family: var(--font-mono); font-size: 16px; }
  :global(body.dark) .links-tagline { font-family: var(--font-mono); }
  :global(body.dark) .tape { display: none; }
  :global(body.dark) .links-avatar { transform: none; }

  @media (max-width: 480px) {
    .links-wrap { padding: 44px 18px 36px; }
    .links-name { font-size: 26px; }
    .link-label { font-size: 16px; }
  }
</style>
