---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — Story not found"
  description="The page you were looking for does not exist."
>
  <div class="not-found container">
    <div class="nf-masthead">
      <span class="nf-vol text-label">Vol. MMXXVI · No. 404</span>
      <h1 class="nf-headline">Story not found.</h1>
      <div class="nf-dateline text-label">
        Dhaka, {new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
      </div>
    </div>
    <div class="nf-rule"></div>
    <p class="nf-body">
      The page you requested could not be located in our archives.
      It may have been moved, removed, or may never have existed.
      Our editorial team regrets the inconvenience.
    </p>
    <a href="/" class="nf-home">← Return to front page</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    padding: 80px 0 120px;
    max-width: 640px;
  }

  .nf-masthead { margin-bottom: 24px; }

  .nf-vol { display: block; margin-bottom: 16px; }

  .nf-headline {
    font-family: var(--font-serif);
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-bottom: 16px;
    transition: color 0.6s ease;
  }

  .nf-rule {
    width: 100%;
    height: 2px;
    background: var(--ink);
    margin-bottom: 24px;
    transition: background 0.6s ease;
  }

  .nf-body {
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.7;
    color: var(--ink-soft);
    margin-bottom: 32px;
    transition: color 0.6s ease;
  }

  .nf-home {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--red);
    text-decoration: underline;
    text-underline-offset: 3px;
    letter-spacing: 0.05em;
  }

  :global(body.dark) .nf-headline { font-family: var(--font-mono); }
</style>
