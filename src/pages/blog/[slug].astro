---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, date, excerpt } = post.data;

const words = post.body.split(/\s+/).length;
const readingTime = Math.max(1, Math.round(words / 200));

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const idx = allPosts.findIndex(p => p.slug === post.slug);
const prev = idx > 0 ? allPosts[idx - 1] : null;
const next = idx < allPosts.length - 1 ? allPosts[idx + 1] : null;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: excerpt,
  author: { '@type': 'Person', name: 'Rumman Kalam', url: 'https://rummankalam.com' },
  datePublished: date.toISOString(),
  url: Astro.url.href,
};
---

<ArticleLayout title={title} description={excerpt} date={date} readingTime={readingTime} jsonLd={jsonLd}>
  <Content />

  {(prev || next) && (
    <nav class="post-nav" aria-label="Post navigation">
      <hr class="post-nav-rule" />
      <div class="post-nav-inner">
        {prev && (
          <a href={`/blog/${prev.slug}`} class="nav-prev">
            <span class="nav-dir">← Previous</span>
            <span class="nav-title">{prev.data.title}</span>
          </a>
        )}
        {next && (
          <a href={`/blog/${next.slug}`} class="nav-next">
            <span class="nav-dir">Next →</span>
            <span class="nav-title">{next.data.title}</span>
          </a>
        )}
      </div>
    </nav>
  )}
</ArticleLayout>

<style>
  .post-nav { margin-top: var(--space-10); }
  .post-nav-rule { border: none; border-top: 0.5px solid var(--rule); margin-bottom: var(--space-8); }
  .post-nav-inner { display: flex; justify-content: space-between; gap: 32px; }

  .nav-prev, .nav-next {
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-width: 260px;
    transition: color 0.15s ease;
  }

  .nav-next { align-items: flex-end; margin-left: auto; }

  .nav-dir { font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); font-weight: 500; }

  .nav-title {
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.3;
    color: var(--ink);
    transition: color 0.15s ease;
  }

  .nav-prev:hover .nav-title,
  .nav-next:hover .nav-title { color: var(--red); }

  :global(body.dark) .nav-title { font-family: var(--font-mono); }
</style>
