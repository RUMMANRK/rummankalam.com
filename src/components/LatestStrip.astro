---
import { getCollection } from 'astro:content';

const publications = await getCollection('publications');
const posts = await getCollection('posts', ({ data }) => !data.draft);

const pubItems = publications.map(p => ({
  title: p.data.title,
  outlet: p.data.outlet,
  type: p.data.type,
  date: p.data.date,
  href: p.data.sourceUrl,
  external: true,
}));

const postItems = posts.map(p => ({
  title: p.data.title,
  outlet: 'Blog',
  type: 'Post',
  date: p.data.date,
  href: `/blog/${p.slug}`,
  external: false,
}));

const latest = [...pubItems, ...postItems]
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 3);

function fmtDate(d: Date) {
  return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
}
---

<div class="latest-grid">
  {latest.map(item => (
    <article class="latest-card">
      <a
        href={item.href}
        target={item.external ? '_blank' : undefined}
        rel={item.external ? 'noopener noreferrer' : undefined}
        class="card-link"
        aria-label={item.title}
      >
        <div class="latest-meta">
          <span class="latest-outlet">{item.outlet}</span>
          <time datetime={item.date.toISOString().split('T')[0]}>{fmtDate(item.date)}</time>
        </div>
        <h3 class="latest-title">{item.title}</h3>
        <div class="latest-type">{item.type}</div>
      </a>
    </article>
  ))}
</div>

<style>
  .latest-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 36px;
  }

  .latest-card {
    padding-top: 14px;
    border-top: 1.5px solid var(--ink);
    transition: transform 0.25s cubic-bezier(0.2, 0.9, 0.3, 1), border-color 0.6s ease;
  }

  .latest-card:hover {
    transform: translateY(-3px);
  }

  .latest-card:hover .latest-title {
    color: var(--red);
  }

  .card-link {
    display: block;
    text-decoration: none;
  }

  .latest-meta {
    display: flex;
    justify-content: space-between;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 12px;
    color: var(--muted);
    transition: color 0.6s ease;
  }

  .latest-outlet {
    color: var(--red);
    font-weight: 500;
  }

  .latest-title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 20px;
    line-height: 1.25;
    color: var(--ink);
    margin: 0;
    transition: color 0.2s ease;
    letter-spacing: -0.012em;
  }

  .latest-type {
    margin-top: 12px;
    font-size: 12px;
    color: var(--muted);
    font-style: italic;
    font-family: var(--font-serif);
    transition: color 0.6s ease;
  }

  :global(body.dark) .latest-meta,
  :global(body.dark) .latest-type { font-family: var(--font-mono); }
  :global(body.dark) .latest-title { font-family: var(--font-mono); font-size: 16px; font-weight: 500; letter-spacing: 0; }

  @media (max-width: 900px) {
    .latest-grid { grid-template-columns: 1fr; gap: 28px; }
    .latest-card { text-align: center; max-width: 440px; margin: 0 auto; width: 100%; }
    .latest-meta { justify-content: center; gap: 12px; }
  }
</style>
