---
interface Props {
  title: string;
  outlet: string;
  type: string;
  date: Date;
  excerpt: string;
  sourceUrl: string;
}

const { title, outlet, type, date, excerpt, sourceUrl } = Astro.props;

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
---

<article class="pub-card">
  <a href={sourceUrl} target="_blank" rel="noopener noreferrer" class="pub-link">
    <div class="pub-meta">
      <span class="pub-outlet">{outlet}</span>
      <time datetime={date.toISOString().split('T')[0]}>{fmtDate(date)}</time>
    </div>
    <h3 class="pub-title">{title}</h3>
    <p class="pub-excerpt">{excerpt}</p>
    <div class="pub-type">{type}</div>
  </a>
</article>

<style>
  .pub-card {
    padding-top: 14px;
    border-top: 1.5px solid var(--ink);
    transition: transform 0.2s ease, border-color 0.6s ease;
  }

  .pub-card:hover { transform: translateY(-2px); }
  .pub-card:hover .pub-title { color: var(--red); }

  .pub-link { display: block; }

  .pub-meta {
    display: flex;
    justify-content: space-between;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 10px;
    color: var(--muted);
  }

  .pub-outlet { color: var(--red); font-weight: 500; }

  .pub-title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 18px;
    line-height: 1.3;
    color: var(--ink);
    margin: 0 0 8px;
    letter-spacing: -0.01em;
    transition: color 0.2s ease;
  }

  .pub-excerpt {
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0 0 10px;
    transition: color 0.6s ease;
  }

  .pub-type {
    font-size: 11px;
    color: var(--muted);
    font-style: italic;
    font-family: var(--font-serif);
  }

  :global(body.dark) .pub-title,
  :global(body.dark) .pub-excerpt,
  :global(body.dark) .pub-meta,
  :global(body.dark) .pub-type { font-family: var(--font-mono); }
  :global(body.dark) .pub-title { font-size: 15px; }
</style>
