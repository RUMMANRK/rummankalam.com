---
interface Props {
  label?: string;
  class?: string;
}

const { label = 'reveal email', class: cls = '' } = Astro.props;

// Plaintext lives only in Astro frontmatter (server-side).
// Rendered HTML only ever contains the offset char-code array — defeats plain-regex scrapers.
const EMAIL = 'rumman@rantages.com';
const OFFSET = 7;
const encoded = Array.from(EMAIL).map(c => c.charCodeAt(0) + OFFSET).join(',');
---

<span class:list={['reveal-email', cls]} data-e={encoded} data-o={OFFSET}>
  <button type="button" class="reveal-btn">{label}</button>
</span>

<style>
  .reveal-btn {
    background: transparent;
    border: none;
    padding: 0;
    color: inherit;
    font: inherit;
    cursor: pointer;
    text-decoration: underline;
    text-decoration-color: var(--red);
    text-underline-offset: 3px;
    transition: color 0.15s ease;
  }
  .reveal-btn:hover { color: var(--red); }
  :global(.revealed-email) {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s ease;
  }
  :global(.revealed-email:hover) { color: var(--red); }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.reveal-email').forEach(wrap => {
    const btn = wrap.querySelector<HTMLButtonElement>('.reveal-btn');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const codes = (wrap.dataset.e ?? '').split(',').map(Number);
      const offset = Number(wrap.dataset.o ?? '0');
      const email = String.fromCharCode(...codes.map(c => c - offset));
      const a = document.createElement('a');
      a.href = 'mailto:' + email;
      a.textContent = email;
      a.className = 'revealed-email';
      // Preserve any class applied by the parent wrapper (e.g. contact-value styling)
      const inherit = btn.dataset.inherit;
      if (inherit) a.className += ' ' + inherit;
      btn.replaceWith(a);
    });
  });
</script>
