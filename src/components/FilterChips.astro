---
interface Props {
  groups: {
    key: string;
    label: string;
    values: string[];
  }[];
  active: Record<string, string>;
}

const { groups, active } = Astro.props;
---

<div class="filter-chips" id="filterChips">
  {groups.map(group => (
    <div class="chip-group">
      <span class="chip-group-label text-label">{group.label}</span>
      <div class="chip-row">
        <button
          class:list={['chip', { 'chip--active': !active[group.key] }]}
          data-group={group.key}
          data-value=""
        >
          All
        </button>
        {group.values.map(val => (
          <button
            class:list={['chip', { 'chip--active': active[group.key] === val }]}
            data-group={group.key}
            data-value={val}
          >
            {val}
          </button>
        ))}
      </div>
    </div>
  ))}
</div>

<style>
  .filter-chips {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 40px;
  }

  .chip-group { display: flex; flex-direction: column; gap: 8px; }

  .chip-group-label { margin-bottom: 4px; }

  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .chip {
    padding: 4px 12px;
    border: 1px solid var(--rule);
    background: none;
    color: var(--ink);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }

  .chip:hover,
  .chip--active {
    background: var(--red);
    color: #fff;
    border-color: var(--red);
  }

  :global(body.dark) .chip { font-family: var(--font-mono); }
  :global(body.dark) .chip--active { color: #000; }
</style>
