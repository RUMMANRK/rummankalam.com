---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg
  class:list={['reg-mark', className]}
  viewBox="0 0 20 20"
  aria-hidden="true"
>
  <circle cx="10" cy="10" r="7" fill="none" stroke="currentColor" stroke-width="0.6"/>
  <line x1="10" y1="1" x2="10" y2="19" stroke="currentColor" stroke-width="0.6"/>
  <line x1="1" y1="10" x2="19" y2="10" stroke="currentColor" stroke-width="0.6"/>
</svg>

<style>
  .reg-mark {
    position: absolute;
    width: 18px;
    height: 18px;
    opacity: 0.4;
    pointer-events: none;
  }
</style>
