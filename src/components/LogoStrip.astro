---
import logosData from '../content/data/logos.json';

const tiles = [...logosData].sort((a, b) => a.order - b.order);

const styleClass: Record<string, string> = {
  'sans-bold': 'lg-sans-bold',
  'serif-medium': 'lg-serif-medium',
  'sans-spaced': 'lg-sans-spaced',
  'sans-heavy-spaced': 'lg-sans-heavy-spaced',
  'serif-italic': 'lg-serif-italic',
  'serif-bold-sm': 'lg-serif-bold-sm',
  'sans-light-sm': 'lg-sans-light-sm',
};
---

<div class="logo-grid">
  {tiles.map(tile => (
    <div class:list={['logo-tile', styleClass[tile.style] ?? 'lg-sans-bold']}>
      {tile.name}
    </div>
  ))}
</div>

<style>
  .logo-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px 14px;
  }

  .logo-tile {
    height: 84px;
    padding: 8px 10px;
    border: 0.5px solid rgba(0, 0, 0, 0.55);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    line-height: 1.15;
    color: var(--ink);
    cursor: default;
    transition: background 0.25s ease, color 0.25s ease, border-color 0.6s ease;
  }

  .logo-tile:hover {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }

  :global(body.dark) .logo-tile {
    border-color: rgba(255, 255, 255, 0.2);
  }

  :global(body.dark) .logo-tile:hover {
    background: var(--red);
    color: #000;
    border-color: var(--red);
  }

  /* Typography styles */
  .lg-sans-bold       { font-family: var(--font-sans); font-weight: 500; font-size: 18px; letter-spacing: -0.01em; }
  .lg-serif-medium    { font-family: var(--font-serif); font-weight: 500; font-size: 17px; }
  .lg-sans-spaced     { font-family: var(--font-sans); font-weight: 600; font-size: 20px; letter-spacing: 0.36em; padding-left: 12px; }
  .lg-sans-heavy-spaced { font-family: var(--font-sans); font-weight: 600; font-size: 24px; letter-spacing: 0.16em; }
  .lg-serif-italic    { font-family: var(--font-serif); font-style: italic; font-size: 18px; }
  .lg-serif-bold-sm   { font-family: var(--font-serif); font-weight: 700; font-size: 14px; }
  .lg-sans-light-sm   { font-family: var(--font-sans); font-weight: 300; font-size: 14px; letter-spacing: 0.05em; }

  @media (max-width: 900px) {
    .logo-grid {
      grid-template-columns: repeat(2, 1fr);
      max-width: 440px;
      margin: 0 auto;
    }
    .logo-tile { height: 72px; }
  }
</style>
