---
import '../styles/global.css';
import Grain from '../components/Grain.astro';
import PaperTexture from '../components/PaperTexture.astro';
import Masthead from '../components/Masthead.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
}

const { title, description, ogImage, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <SEO
    title={title}
    description={description}
    ogImage={ogImage}
    jsonLd={jsonLd}
  />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <!-- Restore saved theme before first paint to prevent FOUC -->
  <script is:inline>
    try {
      if (localStorage.getItem('theme') === 'dark') {
        document.documentElement.setAttribute('data-theme-init', 'dark');
      }
    } catch {}
  </script>
</head>
<body>
  <!-- Apply dark class immediately if saved -->
  <script is:inline>
    try {
      if (localStorage.getItem('theme') === 'dark') {
        document.body.classList.add('dark');
      }
    } catch {}
  </script>

  <PaperTexture />
  <Grain />
  <Masthead />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
</body>
</html>
