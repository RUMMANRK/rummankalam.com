---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date?: Date;
  readingTime?: number;
  jsonLd?: Record<string, unknown>;
}

const { title, description, date, readingTime, jsonLd } = Astro.props;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="article-wrap container">
    <header class="article-header">
      <h1 class="article-title">{title}</h1>
      {(date || readingTime) && (
        <div class="article-byline text-label">
          {date && (
            <time datetime={date.toISOString().split('T')[0]}>
              {date.toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' })}
            </time>
          )}
          {date && readingTime && <span class="sep">·</span>}
          {readingTime && <span>{readingTime} min read</span>}
        </div>
      )}
    </header>
    <div class="article-body prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .article-wrap {
    padding-block: var(--space-16);
  }

  .article-header {
    margin-bottom: var(--space-10);
    padding-bottom: var(--space-8);
    border-bottom: 0.5px solid var(--rule);
    max-width: 65ch;
  }

  .article-title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(28px, 4vw, 52px);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin-bottom: var(--space-4);
    transition: color 0.6s ease;
  }

  .article-byline {
    margin-top: var(--space-4);
  }

  .sep { color: var(--red); margin-inline: var(--space-2); }

  .article-body {
    max-width: 65ch;
  }

  /* Prose styles */
  .prose :global(p) {
    font-size: 16px;
    line-height: 1.75;
    color: var(--ink-soft);
    margin-bottom: var(--space-6);
    transition: color 0.6s ease;
  }

  .prose :global(h2) {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 500;
    color: var(--ink);
    margin: var(--space-10) 0 var(--space-4);
    letter-spacing: -0.015em;
  }

  .prose :global(h3) {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 500;
    color: var(--ink);
    margin: var(--space-8) 0 var(--space-3);
  }

  .prose :global(a) {
    color: var(--red);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--red);
    padding-left: var(--space-6);
    margin: var(--space-8) 0;
    font-family: var(--font-serif);
    font-size: 20px;
    line-height: 1.5;
    color: var(--ink);
    font-style: italic;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: var(--space-6);
    margin-bottom: var(--space-6);
    color: var(--ink-soft);
  }

  .prose :global(li) {
    list-style: revert;
    font-size: 16px;
    line-height: 1.7;
    margin-bottom: var(--space-2);
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--paper-warm);
    padding: 2px 6px;
    border-radius: 3px;
  }

  .prose :global(hr) {
    border: none;
    border-top: 0.5px solid var(--rule);
    margin: var(--space-10) 0;
  }

  :global(body.dark) .article-title { font-family: var(--font-mono); }
  :global(body.dark) .prose :global(h2),
  :global(body.dark) .prose :global(h3) { font-family: var(--font-mono); }
</style>
